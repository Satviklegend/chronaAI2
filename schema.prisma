generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  avatar      String?
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events        Event[]
  goals         Goal[]
  habits        Habit[]
  insights      Insight[]
  notifications Notification[]

  @@map("users")
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  category    String   @default("personal")
  location    String?
  priority    String   @default("medium")
  status      String   @default("scheduled")
  tags        String[] @default([])
  aiAnalyzed  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@map("events")
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  type         String    @default("short-term")
  category     String    @default("personal")
  targetDate   DateTime?
  hoursPerWeek Float?
  progress     Float     @default(0)
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  name        String
  frequency   String   @default("daily")
  timeOfDay   String?
  duration    Int      @default(30)
  streak      Int      @default(0)
  completions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habits")
}

model Insight {
  id                String   @id @default(cuid())
  userId            String
  type              String   @default("weekly")
  productivityScore Int
  summary           String
  suggestions       Json
  timeBreakdown     Json
  overloadWarning   Boolean  @default(false)
  balanceScore      Int      @default(50)
  focusBlocks       Json     @default("[]")
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("insights")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("reminder")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
